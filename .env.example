# Azure SQL Database
DB_SERVER=kuki-sqlsrv-prod.database.windows.net
DB_NAME=kuki-db-prod
DB_USER=your_admin_username
DB_PASSWORD=your_admin_password

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Azure Blob Storage (for profile photos)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=kukistorageprod;...
AZURE_STORAGE_CONTAINER=profile-photos

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-static-web-app.azurestaticapps.net
